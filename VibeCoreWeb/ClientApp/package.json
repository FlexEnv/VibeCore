{
  "name": "easy-asp-core-react-template-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "fetch-swagger": "tsx scripts/fetch-swagger.ts",
    "generate-client": "orval --config orval.config.ts",
    "update-api": "npm run fetch-swagger && npm run generate-client",
    "watch-api": "npm run update-api && chokidar '../Areas/Api/**' '../Areas/Api/Models/**' '../Models/**' '../Program.cs' -c 'npm run update-api'"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.3",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "chokidar-cli": "^3.0.0",
    "orval": "^7.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
