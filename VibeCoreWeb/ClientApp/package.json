    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "orval": "^8.22.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.3",
    "typescript": "^5.7.2",
